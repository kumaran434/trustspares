
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check Admin status securely
    // Now accepts 'ADMIN', 'admin', or isAdmin: true
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null && userDoc != null && (
        userDoc.data.get('isAdmin', false) == true || 
        userDoc.data.get('role', '') == 'ADMIN' ||
        userDoc.data.get('role', '') == 'admin'
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if true; 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || 
                    (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'kycVerified'])) ||
                    (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletBalance', 'totalDeals']));
    }

    // --- DEALS COLLECTION ---
    match /deals/{dealId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || 
                    (isSignedIn() && resource.data.sellerId == request.auth.uid) || 
                    (isSignedIn() && resource.data.buyerId == request.auth.uid) ||
                    (isSignedIn() && resource.data.status == 'AVAILABLE' && request.resource.data.buyerId == request.auth.uid);
      // Explicit delete permission for Admins
      allow delete: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
    }

    // --- INVENTORY LOGS ---
    match /inventory_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- TRANSACTIONS ---
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); 
      allow update: if isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- PLATFORM SETTINGS ---
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
